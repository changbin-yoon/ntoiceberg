<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss} [%-5level] %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- 로컬 테스트 시 Spark 로그 최소화 -->
    <Logger name="org.apache.spark"  level="WARN"  additivity="false"><AppenderRef ref="Console"/></Logger>
    <Logger name="org.apache.hadoop" level="WARN"  additivity="false"><AppenderRef ref="Console"/></Logger>
    <Logger name="org.apache.kafka"  level="WARN"  additivity="false"><AppenderRef ref="Console"/></Logger>
    <Logger name="org.apache.iceberg"level="WARN"  additivity="false"><AppenderRef ref="Console"/></Logger>
    <!-- 본인 코드는 INFO -->
    <Logger name="com.yourcompany"   level="INFO"  additivity="false"><AppenderRef ref="Console"/></Logger>
    <Root level="WARN"><AppenderRef ref="Console"/></Root>
  </Loggers>
</Configuration>
